PORT=5000

# Connection string Neon PostgreSQL
DATABASE_URL=postgresql://user:password@host/neondb?sslmode=require

# Secrets JWT (textes longs et différents, jamais partagés)
JWT_SECRET=ton_secret_jwt_long_et_aleatoire
JWT_REFRESH_SECRET=ton_autre_secret_refresh_different
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Clé API pour les objets IoT (la canne physique)
# La canne doit envoyer ce header : X-IoT-Key: VALEUR_ICI
# Génère une clé aléatoire longue (ex: openssl rand -hex 32)
IOT_API_KEY=genere_une_cle_aleatoire_longue_ici

# Resend (envoi d'emails via API HTTPS, fonctionne sur Render contrairement au SMTP Gmail)
# Cle recuperee sur https://resend.com apres creation du compte
RESEND_API_KEY=re_ta_cle_ici
# Adresse d'expedition. Utilise l'adresse de test Resend en attendant de verifier
# ton propre domaine : onboarding@resend.dev
RESEND_FROM=SmartCane <onboarding@resend.dev>

# URL du frontend (pour CORS) — plusieurs URLs séparées par des virgules
FRONTEND_URL=http://localhost:5173,https://ton-frontend.vercel.app

# URL PUBLIQUE UNIQUE du frontend en production, utilisee dans les liens envoyes
# par email (reset password) et dans les QR codes de reclamation de canne.
# Si absente, la 1ere URL de FRONTEND_URL est utilisee — mais en pratique il vaut
# mieux la definir explicitement pour ne jamais envoyer un lien vers localhost.
PUBLIC_APP_URL=https://ton-frontend.vercel.app
